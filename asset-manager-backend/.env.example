# PostgreSQL
DATABASE_URL=postgresql+asyncpg://patrimoine:password@localhost:5432/patrimoine_db

# Powens
POWENS_CLIENT_ID=your_client_id
POWENS_CLIENT_SECRET=your_client_secret
POWENS_DOMAIN=sandbox.biapi.pro
POWENS_USER_TOKEN=your_user_token

# Binance
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret
BINANCE_TESTNET=true

# Enable Banking (PSD2 — Trade Republic, N26, ...)
ENABLEBANKING_APP_ID=your_application_id
# Clé privée RSA : un chemin vers le .pem (dev local) OU le contenu PEM inline (prod/docker)
ENABLEBANKING_PRIVATE_KEY_PATH=./your_application_id.pem
# ENABLEBANKING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ENABLEBANKING_BASE_URL=https://api.enablebanking.com
ENABLEBANKING_REDIRECT_URL=http://localhost:8000/connect/enablebanking/callback
# Obtenu via scripts/enablebanking-connect.py (Phase 0)
ENABLEBANKING_SESSION_ID=

# App
LOG_LEVEL=INFO
SYNC_ON_STARTUP=true
